model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  username        String?  @unique  
  name            String?
  password        String
  phoneNumber     String
  address         String
  companyName     String   @unique
  driverLicense   String?
  truckType       String?
  loadCapacity    String?
  plateNumber     String?
  yearOfManufacture String?
  role            Role     @default(shipper)

  shipments       Shipment[]
  bids            Bid[]
  jobs            Job[]     @relation("DriverJobs")

  @@index([role])
  @@index([companyName])
}


