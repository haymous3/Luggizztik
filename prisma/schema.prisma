// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum Role {
  carrier
  shipper
}







model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique
  username             String?  @unique
  name                 String?
  password             String
  phoneNumber          String
  role                 Role
  profileImageUrl      String?
  onboardingCompleted  Boolean  @default(false)
  onboardingStep       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipments   Shipment[]
  bids        Bid[]
  driverJobs  Job[]    @relation("DriverJobs")

  carrier     CarrierCompany?
  driver      Driver?

  @@index([role])
}

model CarrierCompany {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  companyName String  @unique
  address     String?

  user        User    @relation(fields: [userId], references: [id])

  trucks      Truck[]
  drivers     Driver[]
  routes      CarrierRoute[]
  profile     CarrierProfile?
  documents   CarrierDocument[]

  createdAt DateTime @default(now())
}



model Driver {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  carrierId     Int
  licenseNumber String

  user          User    @relation(fields: [userId], references: [id])
  carrier       CarrierCompany @relation(fields: [carrierId], references: [id])

  jobs          Job[]
  trucks        Truck[]

  @@index([carrierId])
  createdAt DateTime @default(now())
}

model Truck {
  id               Int     @id @default(autoincrement())
  carrierId        Int
  driverId         Int?

  truckType        String
  loadCapacity     Int
  plateNumber      String  @unique
  yearOfManufacture Int

  status           TruckStatus @default(AVAILABLE)
  imageUrl         String?

  carrier          CarrierCompany @relation(fields: [carrierId], references: [id])
  driver           Driver? @relation(fields: [driverId], references: [id])

  jobs             Job[]
  locations        TruckLocation[]

  @@index([carrierId])
  createdAt DateTime @default(now())
}

enum TruckStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

model TruckType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
}

model Location {
  id        Int @id @default(autoincrement())
  address   String
  city      String
  state     String
  country   String
  latitude  Float
  longitude Float

  pickups   Shipment[] @relation("PickupLocation")
  deliveries Shipment[] @relation("DeliveryLocation")
}


model Shipment {
  id               Int      @id @default(autoincrement())

  cargoType        String
  weight           Int
  distance         Int?

  shipperId        Int
  shipper          User     @relation(fields: [shipperId], references: [id])

  pickupLocationId Int
  deliveryLocationId Int



  pickupLocation   Location @relation("PickupLocation", fields: [pickupLocationId], references: [id])
  deliveryLocation Location @relation("DeliveryLocation", fields: [deliveryLocationId], references: [id])

  pickupDate       DateTime
  deliveryDate     DateTime

  urgent           Boolean  @default(false)
  additionalNote   String?

  budgetMin        Int
  budgetMax        Int

  bids             Bid[]    @relation("ShipmentBids")

  acceptedBidId    Int?     @unique
  acceptedBid      Bid?     @relation("SelectedBid", fields: [acceptedBidId], references: [id])

  job              Job?

  createdAt        DateTime @default(now())

  @@index([shipperId])
  @@index([pickupDate])
  @@index([deliveryDate])
}


enum ShipmentStatus {
  OPEN
  BIDDING
  BID_ACCEPTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}


model Bid {
  id         Int      @id @default(autoincrement())
  amount     Int
  status     BidStatus @default(PENDING)
  createdAt  DateTime @default(now())

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  shipmentId Int
  shipment   Shipment @relation("ShipmentBids", fields: [shipmentId], references: [id])

  selectedFor Shipment? @relation("SelectedBid")

  job        Job?

  @@unique([userId, shipmentId])
  @@index([shipmentId])

}


enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}


model Tracking {
  id         Int      @id @default(autoincrement())

  jobId      Int
  driverId   Int

  latitude   Float
  longitude  Float

  recordedAt DateTime @default(now())

  job        Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([recordedAt])
}



model Job {
  id          Int       @id @default(autoincrement())

  shipmentId  Int       @unique
  shipment    Shipment  @relation(fields: [shipmentId], references: [id])

  driverId    Int
  driver      Driver    @relation(fields: [driverId], references: [id])

  driverUserId Int?
  driverUser   User?    @relation("DriverJobs", fields: [driverUserId], references: [id])

  truckId     Int
  truck       Truck     @relation(fields: [truckId], references: [id])

  bidId       Int       @unique
  bid         Bid       @relation(fields: [bidId], references: [id])

  status      JobStatus @default(CREATED)

  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  trackings          Tracking[]
  shipmentTrackings  ShipmentTracking[]

  @@index([driverId])
  @@index([shipmentId])
}

model CarrierRoute {
  id            Int @id @default(autoincrement())

  carrierId     Int
  originCity    String
  destinationCity String

  frequency     RouteFrequency

  carrier       CarrierCompany @relation(fields: [carrierId], references: [id])

  @@index([originCity, destinationCity])
}

enum RouteFrequency {
  DAILY
  WEEKLY
  OCCASIONAL
}



model TruckLocation {
  id        Int @id @default(autoincrement())

  truckId   Int
  latitude  Float
  longitude Float

  updatedAt DateTime @updatedAt

  truck     Truck @relation(fields: [truckId], references: [id])

  @@index([latitude, longitude])
}


enum JobStatus {
  CREATED
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  LOADING
  LOADED
  IN_TRANSIT
  ARRIVED_DESTINATION
  UNLOADING
  DELIVERED
  COMPLETED
  CANCELLED
}


model ShipmentTracking {
  id        Int @id @default(autoincrement())

  jobId     Int
  latitude  Float
  longitude Float
  speed     Float?

  recordedAt DateTime @default(now())

  job       Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([recordedAt])
}

model PricingRule {
  id           Int @id @default(autoincrement())

  truckType    String
  ratePerKm    Float
  ratePerTon   Float
  baseFare     Float
}


model Review {
  id          Int @id @default(autoincrement())

  shipmentId  Int
  reviewerId  Int
  carrierId   Int

  rating      Int
  comment     String?

  createdAt   DateTime @default(now())
}

model Notification {
  id        Int @id @default(autoincrement())

  userId    Int
  title     String
  message   String

  read      Boolean @default(false)

  createdAt DateTime @default(now())
}


model CarrierVerification {
  id        Int @id @default(autoincrement())

  carrierId Int
  status    VerificationStatus

  documentUrl String?

  createdAt DateTime @default(now())
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}


model CarrierProfile {
  id                   Int      @id @default(autoincrement())
  carrierId            Int      @unique
  carrier              CarrierCompany @relation(fields: [carrierId], references: [id])

  baseCity             String?
  preferredRoutes      String?
  availableDays        String?
  availableFrom        String?
  availableTo          String?
  loadTypes            String?

  preferredJobTypes    String?
  minPrice             Int?
  maxPrice             Int?
  maxDistance           Int?
  notifyMatchingJobs   Boolean  @default(false)
  showOutsidePrefs     Boolean  @default(false)
  notifyWorkHoursOnly  Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}


model CarrierDocument {
  id          Int            @id @default(autoincrement())
  carrierId   Int
  carrier     CarrierCompany @relation(fields: [carrierId], references: [id])

  type        String
  fileName    String
  url         String?
  status      DocumentStatus @default(PENDING)

  createdAt   DateTime @default(now())

  @@index([carrierId])
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}